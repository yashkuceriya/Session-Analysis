# ──────────────────────────────────────────────────────────
# Nerdy: AI-Powered Live Session Analysis
# Production Environment Variables
# ──────────────────────────────────────────────────────────

# ─── Required ─────────────────────────────────────────────

# Authentication (generate random strings for production)
AUTH_SECRET=          # openssl rand -base64 32
ROOM_TOKEN_SECRET=    # openssl rand -base64 32
NEXTAUTH_URL=https://your-domain.com

# AI Analysis (Anthropic Claude API)
ANTHROPIC_API_KEY=    # Get from https://console.anthropic.com

# ─── Database (Supabase — required for production) ────────

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── WebRTC TURN Servers ─────────────────────────────────
# Free tier included by default. For production, get your own:
# https://www.metered.ca/stun-turn or https://xirsys.com

# NEXT_PUBLIC_TURN_URL=turn:a.relay.metered.ca:80
# NEXT_PUBLIC_TURN_USERNAME=your-username
# NEXT_PUBLIC_TURN_CREDENTIAL=your-credential
# NEXT_PUBLIC_TURNS_URL=turn:a.relay.metered.ca:443
# NEXT_PUBLIC_TURNS_TLS_URL=turns:a.relay.metered.ca:443?transport=tcp

# ─── Optional ─────────────────────────────────────────────

# WebSocket signaling server (optional — HTTP polling works without this)
# NEXT_PUBLIC_SIGNALING_URL=wss://your-signaling-server.com

# OAuth providers (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_ID=
# GITHUB_SECRET=

# Development only
# DEV_SKIP_AUTH=true
